# Copy this file to deploy.env and fill in secrets before running scripts/run-with-env.sh
# Only include variables you actually need to override; unspecified ones will use code defaults.
# IMPORTANT: Never commit the real GEMINI_API_KEY to a public repo.

PORT=8080
GEMINI_API_KEY=REPLACE_WITH_REAL_KEY
# API version: v1beta works for all models including GA. v1 for stable GA only.
GEMINI_API_VERSION=v1beta
# Comma separated origins for CORS
ALLOWED_ORIGINS=http://localhost:3000

# Rate limiting
GLOBAL_RATE_LIMIT=100
SESSION_RATE_LIMIT=8
WINDOW_SECONDS=60

# Generation
MAX_TOKENS=1024

# Models — free-tier optimised chain (May 2026).
# gemini-3.1-flash-lite: 15 RPM free (GA since May 7 2026) | gemini-2.5-flash-lite: 10 RPM free = 25 RPM combined.
# gemini-3.1-pro-preview has 0 RPM on free tier — add it as primary only after upgrading to paid.
# The normalizer in geminiClient.ts maps old 2.5/1.5 names automatically.
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_MODELS=gemini-3.1-flash-lite,gemini-2.5-flash-lite

# Persona
CHARLIE_NAME=Charlie
CHARLIE_CREATOR=Charlie Bull
CHARLIE_PERSONA_EXTRA=Focus on DeFi education.

# Token addresses (optional; blank if unknown)
CHAR_TOKEN_ADDRESS=0x7F9532940e98eB7c2da6ba23c3f3D06315BfaAF1
BULL_TOKEN_ADDRESS=
TOKENOMICS_EXTRA=

# Telegram bot (optional)
# Set TELEGRAM_POLLING=true to enable the built-in polling bot.
# Obtain the token from BotFather and keep it secret. Do NOT commit the real value.
TELEGRAM_BOT_TOKEN=
# Comma-separated numeric Telegram user IDs allowed to interact with the bot.
# Leave empty to allow anyone (not recommended). Example: 12345678,987654321
TELEGRAM_ALLOWED_USER_IDS=
# Comma-separated Telegram chat IDs (groups/supergroups) where the bot is allowed to respond.
# If set, the bot ignores all other chats (including DMs). Example: -1001234567890
TELEGRAM_ALLOWED_CHAT_IDS=
# Enable/disable polling loop. Use "true" to start polling on server boot.
TELEGRAM_POLLING=true

# ============================================================================
# Social Media Integration (Bluesky & X/Twitter)
# ============================================================================

# Bluesky Configuration
# Get your credentials from https://bsky.app/settings/app-passwords
BLUESKY_IDENTIFIER=your-handle.bsky.social
BLUESKY_PASSWORD=your-app-password-here
BLUESKY_SERVICE=https://bsky.social

# X/Twitter Configuration
# Get your API keys from https://developer.twitter.com/en/portal/dashboard
X_API_KEY=your-api-key-here
X_API_SECRET=your-api-secret-here
X_ACCESS_TOKEN=your-access-token-here
X_ACCESS_SECRET=your-access-secret-here
X_BEARER_TOKEN=your-bearer-token-here

# Social Media Feature Flags
# Enable/disable automated posting and replies
SOCIAL_POSTS_ENABLED=false
SOCIAL_REPLIES_ENABLED=false
# Dev mode: when true, error details are logged verbosely on post failures.
# Error messages are NEVER posted to social media regardless of this setting.
# Keep false in production.
SOCIAL_DEV_MODE=false

# ============================================================================
# Admin API Key (secures write endpoints)
# ============================================================================
# Set a strong random secret to protect write endpoints:
#   POST /api/social/test/bluesky
#   POST /api/social/test/x
#   POST /api/social/check-interactions
#   POST /api/social/reply/x  (legacy - for future Basic tier X replies)
# Pass as header: Authorization: Bearer <ADMIN_API_KEY>
# If left empty, write endpoints are open (backwards compatible but not recommended in prod).
# Generate one with: openssl rand -hex 32
ADMIN_API_KEY=your-strong-secret-here
